# Copy this file to `.env` and fill in your keys.
#   cp .env.example .env

# --- LLM provider ---------------------------------------------------------
# Options: google (default), openai, huggingface
LLM_PROVIDER=google

# Model for the chosen provider.
#   google:      gemini-2.5-flash | gemini-2.5-pro
#   openai:      gpt-4o-mini | gpt-4o
#   huggingface: e.g. microsoft/Phi-3-mini-4k-instruct (experimental)
LLM_MODEL=gemini-2.5-flash

# --- API keys -------------------------------------------------------------
# Required: web search (free key at https://tavily.com)
TAVILY_API_KEY=

# Required if LLM_PROVIDER=google (free key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=
